{
  "name": "mulertech/class-manipulation",
  "description": "This Class manipulate classes",
  "type": "library",
  "keywords": ["php", "class", "reflection", "manipulation"],
  "minimum-stability": "stable",
  "license": "MIT",
  "authors": [
    {
      "name": "Sébastien Muler",
      "email": "sebastien.muler@mulertech.net"
    }
  ],
  "require": {
    "php": "^8.4"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "mulertech/docker-dev": "^3.2",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^12",
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "MulerTech\\ClassManipulation\\": "./src"
    }
  },
    "autoload-dev": {
        "psr-4": {
        "MulerTech\\ClassManipulation\\Tests\\": "./tests"
        }
    },
  "config": {
    "sort-packages": true
  }
}
